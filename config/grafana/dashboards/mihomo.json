{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "当前连接数",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "mihomo_connections",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "上传速率",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(mihomo_traffic_up_total[1m])",
          "legendFormat": "upload"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "下载速率",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(mihomo_traffic_down_total[1m])",
          "legendFormat": "download"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "平均延迟",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "avg(mihomo_proxy_delay)",
          "legendFormat": "avg delay"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "title": "流量趋势",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(mihomo_traffic_up_total[1m])",
          "legendFormat": "上传"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(mihomo_traffic_down_total[1m])",
          "legendFormat": "下载"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "title": "连接数趋势",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "mihomo_connections",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true
          },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "id": 7,
      "title": "节点延迟",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "mihomo_proxy_delay",
          "legendFormat": "{{name}}"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["mihomo", "proxy"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Mihomo 监控面板",
  "uid": "mihomo-dashboard",
  "version": 1
}
