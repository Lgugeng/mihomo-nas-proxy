# ============================================================
# Mihomo NAS Proxy - Git Ignore
# ============================================================

# ------------------------------------------------------------
# 运行时数据（由 setup.sh 或 docker 自动生成）
# ------------------------------------------------------------
mihomo/config.yaml
mihomo/cache.db
mihomo/*.metadb
mihomo/providers/
mihomo/ui/

# ------------------------------------------------------------
# 环境变量（含订阅链接和密钥）
# ------------------------------------------------------------
.env

# ------------------------------------------------------------
# 归档文件（不应进入版本控制）
# ------------------------------------------------------------
*.zip
*.tar.gz
*.tgz

# ------------------------------------------------------------
# 操作系统文件
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# 编辑器 / IDE
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------
# Claude Code
# ------------------------------------------------------------
.claude/
