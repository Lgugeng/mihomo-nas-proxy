# ============================================================
# Mihomo NAS Proxy 环境变量配置
# 使用方法：复制此文件为 .env 并填入你的配置
# ============================================================

# Clash 订阅链接（必填）
CLASH_SUBSCRIPTION_URL=https://your-subscription-url-here

# 第二个订阅源（可选，留空则不启用）
CLASH_SUBSCRIPTION_URL_2=

# API 密钥（建议使用随机强密码，留空则自动生成）
MIHOMO_SECRET=

# NAS 本地 IP（用于文档说明）
NAS_IP=192.168.1.100

# 是否启用 TUN 模式（true/false，默认 false）
# 启用后所有设备自动走代理，无需单独配置
ENABLE_TUN=false

# ============================================================
# 健康监控告警（可选，留空则不启用告警推送）
# ============================================================

# Bark 推送（iOS）
# 获取方式：App Store 安装 Bark，打开后复制推送 URL
# 格式：https://api.day.app/YOUR_KEY
BARK_URL=

# Telegram Bot 推送
# 获取方式：@BotFather 创建 Bot，获取 Token；@userinfobot 获取 Chat ID
# 格式：https://api.telegram.org/botYOUR_TOKEN/sendMessage?chat_id=YOUR_CHAT_ID
TELEGRAM_URL=
